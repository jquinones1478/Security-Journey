#!/usr/bin/env python3

import http.server
import socketserver
import os
import urllib.parse
import logging
from datetime import datetime

# ----------------------------
# Configuration
# ----------------------------

HOST = "0.0.0.0"
PORT = 8080

# Fake filesystem root (only this tree is ever exposed)
FAKE_ROOT = os.path.abspath("./honeypot_fs")

LOG_FILE = "honeypot.log"

# ----------------------------
# Logging setup
# ----------------------------

logging.basicConfig(
    filename=LOG_FILE,
    level=logging.INFO,
    format="%(message)s"
)

def log_event(client_ip, path, user_agent, status, note=""):
    timestamp = datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")
    msg = (
        f"[{timestamp}] {client_ip} requested {path} | "
        f"UA: {user_agent} | status={status}"
    )
    if note:
        msg += f" | note={note}"
    logging.info(msg)
    print(msg)


# ----------------------------
# Helper functions
# ----------------------------

def is_traversal(path):
    lowered = path.lower()
    if ".." in lowered:
        return True
    if "%2e%2e" in lowered:
        return True
    return False

def safe_join(root, requested_path):
    """
    Join requested_path to root safely, ensuring it stays inside root.
    """
    # Remove query string and fragment
    parsed = urllib.parse.urlparse(requested_path)
    clean_path = parsed.path

    # Normalize and strip leading slash
    clean_path = os.path.normpath(clean_path).lstrip("/")

    # Build full path under fake root
    full_path = os.path.abspath(os.path.join(root, clean_path))

    # Ensure the path is still under FAKE_ROOT
    if not full_path.startswith(root):
        return None

    return full_path


# ----------------------------
# HTTP handler
# ----------------------------

class HoneypotHandler(http.server.BaseHTTPRequestHandler):
    server_version = "Apache/2.4.41 (Ubuntu)"  # Deceptive banner
    sys_version = ""

    def do_GET(self):
        client_ip = self.client_address[0]
        user_agent = self.headers.get("User-Agent", "-")

        # Detect traversal attempts early
        if is_traversal(self.path):
            self.send_response(403)
            self.send_header("Content-Type", "text/html")
            self.end_headers()
            body = b"<html><body><h1>403 Forbidden</h1></body></html>"
            self.wfile.write(body)
            log_event(client_ip, self.path, user_agent, 403, note="Traversal attempt")
            return

        target_path = safe_join(FAKE_ROOT, self.path)
        if target_path is None:
            # Attempt to break out of fake root
            self.send_response(403)
            self.send_header("Content-Type", "text/html")
            self.end_headers()
            body = b"<html><body><h1>403 Forbidden</h1></body></html>"
            self.wfile.write(body)
            log_event(client_ip, self.path, user_agent, 403, note="Escape attempt")
            return

        if os.path.isdir(target_path):
            # Optionally serve a fake index listing
            self._serve_directory_listing(target_path, client_ip, user_agent)
        elif os.path.isfile(target_path):
            self._serve_file(target_path, client_ip, user_agent)
        else:
            self.send_response(404)
            self.send_header("Content-Type", "text/html")
            self.end_headers()
            body = b"<html><body><h1>404 Not Found</h1></body></html>"
            self.wfile.write(body)
            log_event(client_ip, self.path, user_agent, 404, note="File not found")

    def log_message(self, format, *args):
        # Suppress default stdout logging from BaseHTTPRequestHandler
        return

    def _serve_file(self, filepath, client_ip, user_agent):
        try:
            with open(filepath, "rb") as f:
                content = f.read()
        except Exception as e:
            self.send_response(500)
            self.send_header("Content-Type", "text/html")
            self.end_headers()
            body = b"<html><body><h1>500 Internal Server Error</h1></body></html>"
            self.wfile.write(body)
            log_event(client_ip, self.path, user_agent, 500, note=f"Read error: {e}")
            return

        # Very simple content-type guessing
        if filepath.endswith(".txt"):
            ctype = "text/plain"
        elif filepath.endswith(".html") or filepath.endswith(".htm"):
            ctype = "text/html"
        elif filepath.endswith(".conf"):
            ctype = "text/plain"
        elif filepath.endswith(".log"):
            ctype = "text/plain"
        else:
            ctype = "application/octet-stream"

        self.send_response(200)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(content)))
        self.end_headers()
        self.wfile.write(content)

        log_event(client_ip, self.path, user_agent, 200, note=f"Served file: {filepath}")

    def _serve_directory_listing(self, dirpath, client_ip, user_agent):
        try:
            entries = os.listdir(dirpath)
        except Exception as e:
            self.send_response(500)
            self.send_header("Content-Type", "text/html")
            self.end_headers()
            body = b"<html><body><h1>500 Internal Server Error</h1></body></html>"
            self.wfile.write(body)
            log_event(client_ip, self.path, user_agent, 500, note=f"Dir read error: {e}")
            return

        # Simple fake index page
        rel_path = os.path.relpath(dirpath, FAKE_ROOT)
        if rel_path == ".":
            rel_path = "/"
        else:
            rel_path = "/" + rel_path.replace("\\", "/")

        html = [
            "<html><head><title>Index of {}</title></head><body>".format(rel_path),
            "<h1>Index of {}</h1>".format(rel_path),
            "<hr><pre>"
        ]

        # Parent directory link (fake, but looks real)
        if rel_path != "/":
            parent = os.path.dirname(rel_path.rstrip("/"))
            if not parent:
                parent = "/"
            html.append('<a href="{}">../</a>'.format(parent))

        for name in sorted(entries):
            full = os.path.join(dirpath, name)
            display_name = name + ("/" if os.path.isdir(full) else "")
            link_name = urllib.parse.quote(display_name)
            html.append('<a href="{}">{}</a>'.format(link_name, display_name))

        html.append("</pre><hr></body></html>")
        body = "\n".join(html).encode("utf-8")

        self.send_response(200)
        self.send_header("Content-Type", "text/html")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

        log_event(client_ip, self.path, user_agent, 200, note=f"Served directory: {dirpath}")


# ----------------------------
# Main
# ----------------------------

def main():
    if not os.path.isdir(FAKE_ROOT):
        print(f"[!] Fake root directory does not exist: {FAKE_ROOT}")
        print("[!] Create it and populate with decoy files before running.")
        return

    with socketserver.TCPServer((HOST, PORT), HoneypotHandler) as httpd:
        print(f"[+] Honeypot listening on {HOST}:{PORT}")
        print(f"[+] Serving fake filesystem from: {FAKE_ROOT}")
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            print("\n[+] Shutting down honeypot...")
            httpd.server_close()

if __name__ == "__main__":
    main()

